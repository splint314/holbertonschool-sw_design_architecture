classDiagram
    class Library {
        +list books
        +list users
        +list loans
        +add_book(book: Book)
        +register_user(user: User)
        +create_loan(book: Book, user: User) Loan
    }

    class Book {
        +str title
        +str author
        +bool is_available
        +mark_as_unavailable()
        +mark_as_available()
    }

    class User {
        +str name
        +str email
    }

    class Loan {
        +str start_date
        +str end_date
        +close_loan()
    }

    Library "1" -- "*" Book : manages
    Library "1" -- "*" User : manages
    Library "1" -- "*" Loan : manages
    Loan "*" -- "1" Book : references
    Loan "*" -- "1" User : references